{
  "name": "metu",
  "version": "0.1.0",
  "private": true,
  "description": "METU — Digital Marketplace Platform (CPE241 Database Systems · KMUTT G.8 Demo)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "db:generate": "npm run -w @metu/db generate",
    "db:migrate": "npm run -w @metu/db migrate",
    "db:seed": "npm run -w @metu/db seed",
    "db:reset": "npm run -w @metu/db reset",
    "db:studio": "npm run -w @metu/db studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
