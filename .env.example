# Copy this file to .env at the repo root before running.

# ==== Database (Postgres in Docker) ====
DATABASE_URL="postgresql://metu:metu@localhost:5432/metu?schema=public"

# ==== API ====
API_PORT=4000
API_URL="http://localhost:4000"
JWT_SECRET="dev-only-replace-me-with-32-bytes-minimum-for-demo"
COOKIE_DOMAIN=localhost
CORS_ORIGIN="http://localhost:3000"

# ==== Web ====
NEXT_PUBLIC_API_URL="http://localhost:4000"
WEB_PORT=3000

# ==== Node ====
NODE_ENV=development
